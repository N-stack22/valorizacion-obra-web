{
  "name": "tanstack_start_ts",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 127.0.0.1 --port 5173",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run src/lib/auth-policy.test.ts src/lib/security-access.test.ts",
    "test:roles": "vitest run src/lib/auth-policy.test.ts src/lib/workflow.test.ts",
    "test:whitebox": "vitest run src/lib/white-box-domain-logic.test.ts src/lib/security-access.test.ts src/lib/auth-policy.test.ts",
    "test:techniques": "vitest run src/lib/black-box-techniques.test.ts src/lib/white-box-domain-logic.test.ts",
    "test:blackbox": "playwright test e2e/security-auth.spec.ts e2e/smoke.spec.ts",
    "test:volume": "vitest run src/lib/volume-stress.performance.test.ts",
    "test:stress": "vitest run src/lib/volume-stress.performance.test.ts",
    "test:performance": "vitest run src/lib/volume-stress.performance.test.ts",
    "test:usability": "vitest run src/lib/usability.compliance.test.ts",
    "test:installation": "npm ci --ignore-scripts && npm run build",
    "test:docs": "vitest run src/lib/documentation.compliance.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage.enabled true --coverage.provider=v8 --coverage.reporter=lcov --coverage.reporter=text-summary",
    "test:load": "npm run k6:load",
    "k6:validate": "node scripts/verify-k6-sonar.mjs --k6",
    "k6:smoke": "node scripts/run-k6.mjs smoke",
    "k6:load": "node scripts/run-k6.mjs load",
    "k6:stress": "node scripts/run-k6.mjs stress",
    "k6:spike": "node scripts/run-k6.mjs spike",
    "k6:soak": "node scripts/run-k6.mjs soak",
    "k6:supabase": "node scripts/run-k6.mjs supabase-read",
    "sonar:verify": "node scripts/verify-sonarsource.cjs",
    "sonar:scan": "sonar-scanner",
    "sonar:local": "bash scripts/sonar-scan.sh",
    "quality:preflight": "node scripts/verify-k6-sonar.mjs && node scripts/verify-sonarsource.cjs",
    "quality": "npm run quality:preflight && npm run lint && npm run typecheck && npm run test:coverage && npm run build"
